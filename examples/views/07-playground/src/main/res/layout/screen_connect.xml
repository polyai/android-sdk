<?xml version="1.0" encoding="utf-8"?>
<!-- Copyright PolyAI Limited — ladybug glyph + playground
     titles, an environment/connector info card with a live DevSettings label + custom badge,
     Resume/Start primary, optional Start New Chat, captions. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="36dp"
        android:paddingBottom="24dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:src="@drawable/ic_ladybug"
            android:tint="#007AFF"
            android:contentDescription="@null" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="PolyMessaging Playground"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Protocol &amp; lifecycle testing"
            android:textColor="#993C3C43"
            android:textSize="15sp" />

        <!-- Info card (corner 14). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:background="@drawable/bg_info_card"
            android:padding="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_dns"
                    android:tint="#007AFF"
                    android:contentDescription="@null" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENVIRONMENT"
                        android:textColor="#993C3C43"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/envValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="messaging.us-1.poly.ai"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="middle" />
                </LinearLayout>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginVertical="12dp"
                android:background="#4A3C3C43" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_key"
                    android:tint="#007AFF"
                    android:contentDescription="@null" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONNECTOR"
                        android:textColor="#993C3C43"
                        android:textSize="11sp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="your connector"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:fontFamily="monospace"
                        android:maxLines="1"
                        android:ellipsize="middle" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/customBadge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="⚙︎ Custom dev settings active"
            android:textColor="#FF9500"
            android:textSize="12sp"
            android:visibility="gone" />
        <Button
            android:id="@+id/primaryAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingVertical="14dp"
            android:textSize="17sp"
            android:drawablePadding="8dp"
            android:text="Start Chat" />
        <Button
            android:id="@+id/startNewAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Start New Chat"
            android:visibility="gone" />
        <TextView
            android:id="@+id/statusCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="#CC007AFF"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
