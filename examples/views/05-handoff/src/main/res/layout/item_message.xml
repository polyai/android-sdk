<?xml version="1.0" encoding="utf-8"?>
<!-- Copyright PolyAI Limited — one chat row; alignment, bubble styling + rich content set per kind in code. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <LinearLayout
        android:id="@+id/outer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Agent name caption (above bubble) — 11sp medium. -->
        <TextView
            android:id="@+id/name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Bubble row: [retry?] [avatar?] [bubble] -->
        <LinearLayout
            android:id="@+id/bubbleRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/retry"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="6dp"
                android:gravity="center"
                android:text="!"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
            <ai.poly.examples.handoff.views.RetryableImageView
                android:id="@+id/avatar"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_placeholder"
                android:visibility="gone" />
            <TextView
                android:id="@+id/bubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textColorLink="#007AFF"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- URL link-cards → their own horizontal carousel (same card), stacked
             ABOVE the image carousel. -->
        <HorizontalScrollView
            android:id="@+id/urlCarousel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:visibility="gone">
            <LinearLayout
                android:id="@+id/urlStack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp" />
        </HorizontalScrollView>

        <!-- Image attachments → horizontal carousel (width pinned in code). -->
        <HorizontalScrollView
            android:id="@+id/imageCarousel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:visibility="gone">
            <LinearLayout
                android:id="@+id/imageStack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp" />
        </HorizontalScrollView>

        <!-- tel: call actions → vertical stack of green buttons. -->
        <LinearLayout
            android:id="@+id/callActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical"
            android:visibility="gone" />

        <!-- Delivery caption (below bubble): "Sending..." / "Tap to retry". -->
        <TextView
            android:id="@+id/delivery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
