<?xml version="1.0" encoding="utf-8"?>
<!-- Copyright PolyAI Limited -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- RECORD_AUDIO is also merged from the :polyvoice library, but declaring it here keeps the
         example self-documenting. INTERNET comes from the library too. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Optional: lets Bluetooth headsets appear in the audio-output picker (call.audio). Without it,
         availableCommunicationDevices simply omits Bluetooth — no crash. The library does NOT declare
         this dangerous permission for you; opt in here (and request the runtime grant) if you want it. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- A microphone foreground service + wake lock keep the call alive when the app is backgrounded —
         Android 9+ otherwise cuts background mic access and throttles the media threads, dropping the
         call. POST_NOTIFICATIONS (API 33+) is for the ongoing-call notification; the call survives even
         if that grant is denied. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PolyVoice">

        <service
            android:name=".CallForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <activity android:name=".CallActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
