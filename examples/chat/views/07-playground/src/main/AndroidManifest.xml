<?xml version="1.0" encoding="utf-8"?>
<!-- Copyright PolyAI Limited -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Agent avatars + attachment images load over the network. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- NetworkMonitor reads device connectivity via ConnectivityManager. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- NewMessageNotifier posts local banners (requested at runtime on API 33+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".PlaygroundApplication"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PolyPlayground">
        <activity android:name=".RootActivity" android:exported="true" android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
