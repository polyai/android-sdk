<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Install-time normal permissions, merged into the host app.
         INTERNET           — open the WebSocket / REST sockets (the transport).
         ACCESS_NETWORK_STATE — observe connectivity to drive reconnection/backoff
                                (via ConnectivityManager.NetworkCallback).
         Deliberately NO POST_NOTIFICATIONS here — notification permission is the
         host app's choice, requested by the sample apps, not forced on every consumer. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

</manifest>
