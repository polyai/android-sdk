<?xml version="1.0" encoding="utf-8"?>
<!-- Copyright PolyAI Limited -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions merged into the host app.
         INTERNET / ACCESS_NETWORK_STATE — open the signaling WebSocket + REST sockets.
         RECORD_AUDIO  — capture the microphone for the call. This is a RUNTIME (dangerous)
                         permission: the SDK declares it here, but the host app is responsible
                         for requesting the grant from the user before starting a call. The
                         call surface fails fast with PolyError.Voice.MediaFailed if it's missing. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Microphone is required for a voice call but the SDK shouldn't block installs on devices
         without one; the host app can tighten this if needed. -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />

</manifest>
